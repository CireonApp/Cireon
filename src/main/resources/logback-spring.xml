<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Define the Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Pattern: [DATE TIME LEVEL] - message -->
            <pattern>[%d{yyyy-MM-dd HH:mm:ss} %level] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Development: normal logging -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.cireonapp.server" level="DEBUG"/>
    </springProfile>

    <!-- Production: only specific app logging -->
    <springProfile name="prod">
        <root level="OFF">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.cireonapp.server.ServerApplication" level="TRACE" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <logger name="org.dizitart.no2" level="OFF"/>
    </springProfile>

</configuration>
